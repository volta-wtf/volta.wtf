{
  "name": "@volta/catalog",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "gen:catalog": "tsx scripts/generate-catalog.ts",
    "predev": "pnpm run gen:catalog && setup-assets",
    "dev": "next dev --turbopack --port 3003",
    "prebuild": "pnpm run gen:catalog && copy-assets",
    "build": "next build",
    "start": "next start --port 3003",
    "lint": "next lint --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@registry/primitives": "workspace:*",
    "@registry/components": "workspace:*",
    "@registry/styles": "workspace:*",
    "@registry/assets": "workspace:*",
    "@registry/interface": "workspace:*",
    "@tailwindcss/postcss": "^4.1.13",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "next": "^15.5.0"
  },
  "devDependencies": {
    "@studio/config-eslint": "workspace:*",
    "@studio/config-typescript": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "@tailwindcss/postcss": "^4.1.13",
    "tailwindcss": "^4.1.13",
    "eslint": "^9.34.0",
    "typescript": "5.9.2",
    "globby": "^14.0.0",
    "postcss-selector-parser": "^6.0.0",
    "gray-matter": "^4.0.3",
    "tsx": "^4.0.0",
    "react-markdown": "^9.0.0"
  }
}