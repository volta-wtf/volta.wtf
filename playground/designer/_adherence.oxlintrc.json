{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/collab/**",
              "components/commands/**",
              "components/data/**",
              "components/designer/**",
              "components/devices/**",
              "components/fields/**",
              "components/icons/**",
              "components/library/**",
              "components/prototype/**",
              "components/tokens/**",
              "components/ui/**",
              "components/utilities/**",
              "ui_kits/editor/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono|Source Serif 4))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono, Source Serif 4."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActionAlign'] > JSXAttribute > JSXIdentifier[name!=/^(?:onAlign|distribute|disabled|className|style|key|ref|className|style|children)$/]",
        "message": "<ActionAlign> doesn't accept that prop. Declared props: onAlign, distribute, disabled, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActionFill'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|onChange|alpha|onAlphaChange|swatches|className|style|key|ref|className|style|children)$/]",
        "message": "<ActionFill> doesn't accept that prop. Declared props: value, defaultValue, onChange, alpha, onAlphaChange, swatches, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActionOpacity'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|onChange|className|style|key|ref|className|style|children)$/]",
        "message": "<ActionOpacity> doesn't accept that prop. Declared props: value, defaultValue, onChange, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActionRotate'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|onChange|onFlipH|onFlipV|className|style|key|ref|className|style|children)$/]",
        "message": "<ActionRotate> doesn't accept that prop. Declared props: value, defaultValue, onChange, onFlipH, onFlipV, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AssetGrid'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|count|children|key|ref|className|style|children)$/]",
        "message": "<AssetGrid> doesn't accept that prop. Declared props: title, count, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|presence|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, presence."
