{
  "$schema": "Typed design tokens (W3C Design Tokens format). Mirror of tokens/*.css — `cssVar` binds each token to its runtime custom property. Consumed by the tokens/ management UI.",
  "version": 1,
  "groups": [
    {
      "id": "color-semantic",
      "name": "Color / Semantic",
      "tokens": [
        { "name": "background",        "$type": "color", "$value": "oklch(0.993 0.0016 84)",       "cssVar": "--background",        "$description": "Warm paper white — app + page surface" },
        { "name": "foreground",        "$type": "color", "$value": "oklch(0.145 0.003 80)",        "cssVar": "--foreground",        "$description": "Default text" },
        { "name": "muted",             "$type": "color", "$value": "oklch(0.970 0.003 82)",        "cssVar": "--muted",             "$description": "Quiet fills" },
        { "name": "muted-foreground",  "$type": "color", "$value": "oklch(0.556 0.005 78)",        "cssVar": "--muted-foreground",  "$description": "Secondary text" },
        { "name": "primary",           "$type": "color", "$value": "oklch(0.205 0.004 80)",        "cssVar": "--primary",           "$description": "Primary action" },
        { "name": "border",            "$type": "color", "$value": "oklch(0.922 0.004 80)",        "cssVar": "--border",            "$description": "Hairlines" },
        { "name": "destructive",       "$type": "color", "$value": "oklch(0.577 0.245 27.325)", "cssVar": "--destructive",       "$description": "Danger" },
        { "name": "brand",             "$type": "color", "$value": "oklch(0.66 0.13 43)",          "cssVar": "--brand",             "$description": "Terracotta — editorial accents only" },
        { "name": "selection",         "$type": "color", "$value": "oklch(0.62 0.19 256)",      "cssVar": "--selection",         "$description": "Canvas selection blue" },
        { "name": "canvas",            "$type": "color", "$value": "oklch(0.968 0.003 82)",        "cssVar": "--canvas",            "$description": "Infinite-canvas backdrop" }
      ]
    },
    {
      "id": "font",
      "name": "Typography",
      "tokens": [
        { "name": "font-sans",   "$type": "fontFamily",    "$value": ["Geist", "system-ui", "sans-serif"],      "cssVar": "--font-sans" },
        { "name": "font-mono",   "$type": "fontFamily",    "$value": ["Geist Mono", "ui-monospace", "monospace"], "cssVar": "--font-mono" },
        { "name": "font-serif",  "$type": "fontFamily",    "$value": ["Source Serif 4", "Georgia", "serif"],   "cssVar": "--font-serif", "$description": "Editorial display only — never chrome" },
        { "name": "weight-medium",   "$type": "fontWeight", "$value": 500, "cssVar": "--font-weight-medium" },
        { "name": "weight-semibold", "$type": "fontWeight", "$value": 600, "cssVar": "--font-weight-semibold" },
        { "name": "text-ui",     "$type": "dimension", "$value": "0.8125rem", "cssVar": "--text-ui",    "$description": "Default control text (13px)" },
        { "name": "text-ui-sm",  "$type": "dimension", "$value": "0.75rem",   "cssVar": "--text-ui-sm", "$description": "Panel labels (12px)" },
        { "name": "leading-tight", "$type": "number", "$value": 1.25, "cssVar": "--leading-tight" },
        { "name": "tracking-widest", "$type": "dimension", "$value": "0.08em", "cssVar": "--tracking-widest", "$description": "Uppercase eyebrows" }
      ]
    },
    {
      "id": "dimension",
      "name": "Spacing & Size",
      "tokens": [
        { "name": "spacing",        "$type": "dimension", "$value": "0.25rem", "cssVar": "--spacing", "$description": "4px base unit" },
        { "name": "space-2",        "$type": "dimension", "$value": "0.5rem",  "cssVar": "--space-2" },
        { "name": "space-3",        "$type": "dimension", "$value": "0.75rem", "cssVar": "--space-3" },
        { "name": "space-4",        "$type": "dimension", "$value": "1rem",    "cssVar": "--space-4" },
        { "name": "toolbar-height", "$type": "dimension", "$value": "48px",    "cssVar": "--toolbar-height" },
        { "name": "panel-width",    "$type": "dimension", "$value": "264px",   "cssVar": "--panel-width" },
        { "name": "control-height", "$type": "dimension", "$value": "28px",    "cssVar": "--control-height" },
        { "name": "row-height",     "$type": "dimension", "$value": "32px",    "cssVar": "--row-height" }
      ]
    },
    {
      "id": "radius",
      "name": "Radius",
      "tokens": [
        { "name": "radius",      "$type": "dimension", "$value": "0.625rem", "cssVar": "--radius", "$description": "Seed — the ramp derives from it" },
        { "name": "radius-xs",   "$type": "dimension", "$value": "4px",  "cssVar": "--radius-xs" },
        { "name": "radius-sm",   "$type": "dimension", "$value": "6px",  "cssVar": "--radius-sm" },
        { "name": "radius-md",   "$type": "dimension", "$value": "8px",  "cssVar": "--radius-md" },
        { "name": "radius-lg",   "$type": "dimension", "$value": "10px", "cssVar": "--radius-lg" },
        { "name": "radius-full", "$type": "dimension", "$value": "9999px", "cssVar": "--radius-full" }
      ]
    },
    {
      "id": "shadow",
      "name": "Shadow",
      "tokens": [
        { "name": "shadow-sm",      "$type": "shadow", "$value": [{ "offsetX": "0", "offsetY": "1px", "blur": "3px", "spread": "0", "color": "oklch(0 0 0 / 0.08)" }], "cssVar": "--shadow-sm" },
        { "name": "shadow-popover", "$type": "shadow", "$value": [{ "offsetX": "0", "offsetY": "4px", "blur": "12px", "spread": "-2px", "color": "oklch(0 0 0 / 0.12)" }], "cssVar": "--shadow-popover" },
        { "name": "shadow-drag",    "$type": "shadow", "$value": [{ "offsetX": "0", "offsetY": "16px", "blur": "32px", "spread": "-8px", "color": "oklch(0 0 0 / 0.24)" }], "cssVar": "--shadow-drag" }
      ]
    },
    {
      "id": "motion",
      "name": "Motion",
      "tokens": [
        { "name": "duration-fast", "$type": "duration", "$value": "120ms", "cssVar": "--duration-fast" },
        { "name": "duration",      "$type": "duration", "$value": "160ms", "cssVar": "--duration" },
        { "name": "duration-slow", "$type": "duration", "$value": "240ms", "cssVar": "--duration-slow" },
        { "name": "ease-standard", "$type": "cubicBezier", "$value": [0.2, 0, 0, 1],    "cssVar": "--ease-standard" },
        { "name": "ease-out",      "$type": "cubicBezier", "$value": [0.16, 1, 0.3, 1], "cssVar": "--ease-out" }
      ]
    }
  ]
}
