{
  "explorer.sortOrder": "default",
  "explorer.sortOrderLexicographicOptions": "upper",
  "files.exclude": {
    // Internal
    //".temp": true,
    "apps/{admin,builder,editor}": true,
    "apps/{catalog,catalogo,demos,docs,shad}": false,
    "sites/{www,design,knowledge}": false,
    "templates/{website,sitedocs,miltidocs}": false,
    "templates/": false,
    "packages/css-{presets,primitives,system,materials}": true,

    // Base
    "**/.source": true,
    "**/.{next,turbo,vercel}": true,
    "**/node_modules": true,

    // Config
    "**/.gitkeep": false,
    //"**/.gitignore": true,
    "**/.env*": true,
    "**/.npmrc": true,
    "**/pnpm-*.yaml": true,

    // Apps
    //"**/next-env.d.ts": true,
    //"**/next.config.*": true,
    //"**/eslint.config.*": true,
    //"**/tsconfig.*": true,
    //"**/postcss.*": true,

  },
  "search.exclude": {
    "**/.next": true,
    "**/.turbo": true,
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "pnpm-lock.yaml": true,
  }
}
